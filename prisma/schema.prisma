// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("BUYER")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sellerProfile SellerProfile?
  listings      Listing[]
  orders        Order[]
  sentMessages  Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")
  auditLogs     AuditLog[]
}

model SellerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  businessName String
  businessType String
  taxId       String?
  address     String
  phone       String
  website     String?
  description String
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  fileUrl     String?  // For sample or full file
  sampleUrl   String?
  schema      String?  // JSON schema
  license     String
  status      String   @default("PENDING")
  sellerId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders Order[]
}

model Order {
  id            String    @id @default(cuid())
  buyerId       String
  listingId     String
  amount        Float
  platformFee   Float?
  status        String    @default("PENDING")
  paymentId     String?
  fileUrl       String?   // Delivered file
  deliveredAt   DateTime?
  termsAccepted Boolean   @default(false)
  heldAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  buyer   User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  listing Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  disputes Dispute[]
  messages Message[]
  payment  Payment?
}

model Payment {
  id       String   @id @default(cuid())
  orderId  String   @unique
  stripeId String
  amount   Float
  status   String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Dispute {
  id          String   @id @default(cuid())
  orderId     String
  reason      String
  status      String   @default("OPEN")
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  content   String
  orderId   String?
  createdAt DateTime @default(now())

  from User @relation("MessageSender", fields: [fromId], references: [id], onDelete: Cascade)
  to   User @relation("MessageReceiver", fields: [toId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}
